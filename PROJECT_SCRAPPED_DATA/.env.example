# MIDAN Data Pipeline -- Environment Configuration
# Copy to .env and fill in API keys as needed

# Reddit API (Phase 2) -- get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MIDAN:v2.0 (by /u/your_username)

# Ollama Local LLM (Phase 2) -- optional
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Product Hunt API (Phase 2) -- optional, scrapes public pages without key
PRODUCTHUNT_API_TOKEN=

# Future phases
OPENAI_API_KEY=
