{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["api:api", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Streamlit Dashboard",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": ["run", "app.py"],
      "port": 8501
    },
    {
      "name": "MIDAN Frontend (midan.html)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server"],
      "port": 3002,
      "autoPort": true
    }
  ]
}
